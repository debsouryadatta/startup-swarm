# Neon Postgres (https://neon.tech)
DATABASE_URL=postgresql://...

# Daytona (https://daytona.io)
DAYTONA_API_KEY=

# Supabase Storage (https://supabase.com → project → Settings → API)
# Create a public bucket named "startup-kits" in the Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Your app's public URL (used to build the WEBHOOK_URL sent to the sandbox)
APP_BASE_URL=http://localhost:3000

# NextAuth / Auth.js (https://authjs.dev)
# Generate secret: openssl rand -base64 32
AUTH_SECRET=
# Credentials for the sign-in form (set these to whatever you want)
AUTH_EMAIL=you@example.com
AUTH_PASSWORD=changeme
